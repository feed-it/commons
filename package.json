{
	"name": "@lib-feedit/commons",
	"version": "1.20.2",
	"description": "Reusable components, scripts, styles, hooks & more",
	"author": "Feed'it",
	"license": "UNLICENSED",
	"keywords": [
		"react-components",
		"react"
	],
	"main": "dist/client/index.js",
	"module": "dist/client/index.esm.js",
	"types": "dist/client/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"require": "./dist/client/index.js",
			"import": "./dist/client/index.esm.js",
			"types": "./dist/client/index.d.ts"
		},
		"./client": {
			"require": "./dist/client/index.js",
			"import": "./dist/client/index.esm.js",
			"types": "./dist/client/index.d.ts"
		},
		"./server": {
			"require": "./dist/server/index.js",
			"import": "./dist/server/index.esm.js",
			"types": "./dist/server/index.d.ts"
		},
		"./eslint.mjs": "./dist/client/eslint.mjs",
		"./client/rc-slider.css": "./dist/client/rc-slider.css"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/feed-it/commons.git"
	},
	"scripts": {
		"dev": "nodemon",
		"build": "rollup -c --bundleConfigAsCjs",
		"lint": "biome lint src",
		"lint:fix": "biome check src --write",
		"lint:strict": "biome lint src --max-diagnostics=0",
		"format": "biome format src --write",
		"release": "standard-version && git push --follow-tags"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@inquirer/prompts": "^8.3.0",
		"@rollup/plugin-commonjs": "^29.0.1",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/js-yaml": "^4.0.9",
		"@types/lodash.debounce": "^4.0.9",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"chalk": "^5.6.2",
		"js-yaml": "^4.1.1",
		"lodash.debounce": "^4.0.8",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.1",
		"rc-slider": "^11.1.9",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rollup": "^4.59.0",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-dts": "^6.3.0",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"rollup-plugin-postcss": "^4.0.2",
		"sass": "^1.97.3",
		"standard-version": "^9.5.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.30.3"
}
